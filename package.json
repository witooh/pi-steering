{
  "name": "pi-steering",
  "version": "0.1.0",
  "description": "Load Kiro steering files into Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "kiro",
    "steering"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/witooh/pi-steering.git"
  },
  "files": [
